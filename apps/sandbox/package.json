{
  "name": "chatbot-ui-sandbox",
  "version": "1.0.0",
  "description": "Sandbox environment for chatbot-ui web development",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sw": "node build-sw.js --watch",
    "build": "vite build && npm run build:sw",
    "build:dev": "vite build --mode preview && npm run build:sw",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "build:sw": "node build-sw.js",
    "preview": "vite preview",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "esbuild": "^0.27.2",
    "typescript": "catalog:",
    "vite": "catalog:",
    "wrangler": "catalog:"
  },
  "dependencies": {
    "@pubwiki/sandbox-client": "workspace:*",
    "@pubwiki/sandbox-service": "workspace:*",
    "esbuild-wasm": "^0.27.2"
  }
}
