{
  "name": "pubwiki-sandbox",
  "compatibility_date": "2026-01-04",
  "assets": {
    "directory": "./dist"
  },
  "routes": [
    {
      "pattern": "*.soyo.mu/*",
      "zone_name": "soyo.mu"
    }
  ],
  "env": {
    "dev": {
      "name": "pubwiki-sandbox-dev",
      "routes": [
        {
          "pattern": "*.fus.al/*",
          "zone_name": "fus.al"
        }
      ]
    }
  }
}