{
	"name": "@pubwiki/player",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:dev": "vite build --mode preview",
		"deploy": "wrangler deploy",
		"deploy:dev": "wrangler deploy --env dev",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings --watch",
		"i18n": "pnpm exec paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "catalog:",
		"svelte": "catalog:",
		"svelte-check": "catalog:",
		"@sveltejs/adapter-cloudflare": "catalog:",
		"@sveltejs/kit": "catalog:",
		"@sveltejs/vite-plugin-svelte": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"tailwindcss": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"wrangler": "catalog:"
	},
	"dependencies": {
		"@pubwiki/api": "workspace:*",
		"@pubwiki/bundler": "workspace:*",
		"@pubwiki/chat": "workspace:*",
		"@pubwiki/flow-core": "workspace:*",
		"@pubwiki/rdfstore": "workspace:*",
		"@pubwiki/sandbox-host": "workspace:*",
		"@pubwiki/reader": "workspace:*",
		"@pubwiki/ui": "workspace:*",
		"@pubwiki/vfs": "workspace:*"
	}
}
