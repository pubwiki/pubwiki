{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "pubwiki-player",
  "compatibility_date": "2026-01-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".svelte-kit/cloudflare/_worker.js",
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  },
  "routes": [
    {
      "pattern": "play.pub.wiki",
      "custom_domain": true
    }
  ]
}
