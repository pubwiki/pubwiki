{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".svelte-kit/**"],
      "inputs": ["src/**", "tsconfig.json", "vite.config.*", "svelte.config.*"]
    },
    "generate": {
      "outputs": [
        "src/generated/**",
        "src/validate/schemas.ts",
        "openapi.bundled.yaml",
        "drizzle/**"
      ],
      "inputs": ["openapi.yaml", "src/schema/**", "drizzle.config.*"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "svelte.config.*"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "test:unit": {
      "dependsOn": ["^build"]
    },
    "test:e2e": {
      "dependsOn": ["build"]
    },
    "lint": {}
  }
}
