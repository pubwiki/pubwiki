{
  "name": "@pubwiki/sandbox-service",
  "version": "1.0.0",
  "description": "RPC interface definitions for sandbox-main site communication using capnweb",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./interfaces": {
      "types": "./src/interfaces/index.ts",
      "import": "./src/interfaces/index.ts"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "capnweb": "^0.2.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "sandbox",
    "rpc",
    "capnweb",
    "vfs",
    "bundler"
  ],
  "license": "MIT"
}
