{
  "name": "@pubwiki/world-editor",
  "version": "0.1.0",
  "description": "World editor types, RDF vocabulary, and StateData ↔ TripleStore conversion layer.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./templates/backend.tar.gz": "./dist/templates/backend.tar.gz",
    "./templates/frontend.tar.gz": "./dist/templates/frontend.tar.gz",
    "./templates/game-sdk.tar.gz": "./dist/templates/game-sdk.tar.gz",
    "./templates/game-ui.tar.gz": "./dist/templates/game-ui.tar.gz"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:templates": "npx tsx scripts/pack-templates.ts",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "check": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@pubwiki/chat": "workspace:*",
    "@pubwiki/rdfstore": "workspace:*",
    "@pubwiki/vfs": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@pubwiki/flow-core": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
