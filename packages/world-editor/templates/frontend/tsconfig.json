{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "types": [
      "vite/client"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@pubwiki/game-sdk": [
        "./lib/game-sdk"
      ],
      "@pubwiki/game-sdk/*": [
        "./lib/game-sdk/*"
      ],
      "@pubwiki/game-ui": [
        "./lib/game-ui"
      ],
      "@pubwiki/game-ui/*": [
        "./lib/game-ui/*"
      ],
      "@pubwiki/wiki-rag-lab": [
        "../src"
      ]
    }
  },
  "files": [
    "src/main.tsx"
  ],
  "include": [
    "src",
    "../src"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}