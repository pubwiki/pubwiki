{
  "name": "@pubwiki/lua",
  "version": "0.6.1",
  "type": "module",
  "description": "Browser-friendly Lua 5.4 runtime",
  "main": "./src/index.ts",
  "repository": {
    "url": "git+https://github.com/pubwiki/lua.git",
    "directory": "packages/lua"
  },
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./wasm/*": "./wasm/*"
  },
  "sideEffects": false,
  "files": [
    "dist",
    "wasm",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run && playwright test",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "lua",
    "wasm",
    "mediawiki"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/ui": "catalog:",
    "fake-indexeddb": "^6.2.5",
    "memory-level": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@pubwiki/vfs": "workspace:*"
  }
}
