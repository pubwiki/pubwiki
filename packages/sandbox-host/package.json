{
  "name": "@pubwiki/sandbox-host",
  "version": "1.0.0",
  "description": "Host-side sandbox communication layer for @pubwiki ecosystem",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.browser.config.ts"
  },
  "keywords": [
    "sandbox",
    "rpc",
    "iframe",
    "capnweb",
    "vfs",
    "hmr"
  ],
  "author": "PubWiki",
  "license": "MIT",
  "dependencies": {
    "@pubwiki/bundler": "workspace:*",
    "@pubwiki/sandbox-service": "workspace:*",
    "@pubwiki/sandbox-client": "workspace:*",
    "@pubwiki/vfs": "workspace:*",
    "capnweb": "catalog:"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/web-worker": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite-plugin-top-level-await": "catalog:",
    "vite-plugin-wasm": "catalog:",
    "vitest": "catalog:",
    "zod": "^4.0.0"
  }
}
