{
  "name": "@pubwiki/svelte-chat",
  "version": "0.1.0",
  "description": "Svelte 5 chat UI components built on @pubwiki/chat core library",
  "type": "module",
  "svelte": "./src/lib/index.ts",
  "types": "./src/lib/index.ts",
  "exports": {
    ".": {
      "types": "./src/lib/index.ts",
      "svelte": "./src/lib/index.ts",
      "import": "./src/lib/index.ts"
    },
    "./stores": {
      "types": "./src/lib/stores/index.ts",
      "import": "./src/lib/stores/index.ts"
    },
    "./blocks": {
      "types": "./src/lib/blocks/index.ts",
      "svelte": "./src/lib/blocks/index.ts",
      "import": "./src/lib/blocks/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "package": "svelte-kit sync && svelte-package",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@pubwiki/chat": "workspace:*",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "catalog:",
    "@sveltejs/kit": "catalog:",
    "@sveltejs/package": "catalog:",
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "svelte": "catalog:",
    "svelte-check": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "svelte",
    "chat",
    "ui",
    "components",
    "llm"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pubwiki/pubchat.git",
    "directory": "packages/svelte-chat"
  }
}
