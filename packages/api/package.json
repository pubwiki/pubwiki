{
  "name": "@pubwiki/api",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/generated/openapi.ts",
    "./client": "./src/client.ts",
    "./utils": "./src/utils.ts",
    "./validate": "./src/validate/schemas.ts"
  },
  "scripts": {
    "generate": "openapi-typescript openapi.yaml -o src/generated/openapi.ts && redocly bundle openapi.yaml -o openapi.bundled.yaml && orval",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "better-auth": "^1.5.5",
    "json-canonicalize": "^2.0.0",
    "openapi-fetch": "^0.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@redocly/cli": "^2.21.1",
    "openapi-typescript": "^7.13.0",
    "orval": "^8.5.3",
    "typescript": "catalog:"
  }
}
