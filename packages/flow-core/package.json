{
  "name": "@pubwiki/flow-core",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "dev": "vite build --watch",
    "test": "vitest",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@pubwiki/api": "workspace:*",
    "@pubwiki/chat": "workspace:*",
    "@pubwiki/lua": "workspace:*",
    "@pubwiki/rdfstore": "workspace:*",
    "@pubwiki/vfs": "workspace:*",
    "jsonrepair": "^3.13.2",
    "xxhash-wasm": "^1.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "catalog:",
    "vitest": "^3.0.4"
  }
}
