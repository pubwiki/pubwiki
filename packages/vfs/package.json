{
  "name": "@pubwiki/vfs",
  "version": "1.0.0",
  "description": "Virtual File System library with optional version control support",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "vfs",
    "virtual-file-system",
    "file-system",
    "git"
  ],
  "author": "PubWiki",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "catalog:",
    "isomorphic-git": "^1.29.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {},
  "dependencies": {}
}
