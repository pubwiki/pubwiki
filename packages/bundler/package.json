{
  "name": "@pubwiki/bundler",
  "version": "1.0.0",
  "description": "Frontend bundler library using esbuild-wasm with Virtual File System support",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./worker": {
      "types": "./src/worker/index.ts",
      "import": "./src/worker/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.browser.config.ts",
    "prepublishOnly": "pnpm run build",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "bundler",
    "esbuild",
    "typescript",
    "jsx",
    "tsx",
    "vfs",
    "virtual-file-system",
    "web-worker"
  ],
  "author": "PubWiki",
  "license": "MIT",
  "dependencies": {
    "@pubwiki/vfs": "workspace:*",
    "esbuild-wasm": "^0.27.4"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@vitest/web-worker": "catalog:",
    "playwright": "catalog:",
    "typescript": "catalog:",
    "vite-plugin-top-level-await": "catalog:",
    "vite-plugin-wasm": "catalog:",
    "vitest": "catalog:"
  }
}
