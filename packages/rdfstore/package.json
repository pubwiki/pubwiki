{
  "name": "@pubwiki/rdfstore",
  "version": "1.0.1",
  "description": "RDF store with immutable version DAG and SPARQL support. Uses quadstore (abstract-level) for RDF data and Dexie.js (IndexedDB) for version metadata.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "rdf",
    "quadstore",
    "versioning",
    "dexie",
    "indexeddb"
  ],
  "license": "MIT",
  "dependencies": {
    "@rdfjs/types": "^2.0.1",
    "abstract-level": "catalog:",
    "dexie": "catalog:",
    "diff": "^8.0.3",
    "n3": "catalog:",
    "quadstore": "catalog:",
    "quadstore-comunica": "catalog:"
  },
  "devDependencies": {
    "@types/n3": "catalog:",
    "fake-indexeddb": "^6.2.5",
    "memory-level": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
