{
  "name": "@pubwiki/rdfstore",
  "version": "1.0.1",
  "description": "HAMT-based triple store with versioning, live queries, and pluggable persistence.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "triplestore",
    "hamt",
    "versioning",
    "indexeddb"
  ],
  "license": "MIT",
  "dependencies": {
    "@pubwiki/api": "workspace:*"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.2.5",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
