{
  "name": "@pubwiki/sandbox-llm-client",
  "version": "0.1.2",
  "description": "WikiRAG client library for sandbox environments - provides AI game engine capabilities",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "wikirag",
    "llm",
    "ai",
    "game-engine",
    "sandbox",
    "reactive"
  ],
  "author": "PubWiki Team",
  "license": "MIT",
  "devDependencies": {
    "@pubwiki/wiki-rag-lab": "link:../../wiki-rag-lab",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/pubwiki/pubchat.git",
    "directory": "sandbox-llm-client"
  },
  "publishConfig": {
    "access": "public"
  }
}
