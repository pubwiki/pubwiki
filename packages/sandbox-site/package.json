{
  "name": "chatbot-ui-sandbox",
  "version": "1.0.0",
  "description": "Sandbox environment for chatbot-ui web development",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sw": "node build-sw.js --watch",
    "build": "vite build && npm run build:sw",
    "build:sw": "node build-sw.js",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.19.1",
    "esbuild": "^0.24.2",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  },
  "dependencies": {
    "@pubwiki/sandbox-service": "workspace:*",
    "capnweb": "^0.2.0",
    "esbuild-wasm": "^0.27.0"
  }
}
