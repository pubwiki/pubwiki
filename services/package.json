{
  "name": "pubwiki-backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote",
    "prune-db:local": "rm -rf .wrangler/state && pnpm migrate:local",
    "seed": "tsx scripts/seed-mock-data.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@pubwiki/api": "workspace:*",
    "@pubwiki/db": "workspace:*",
    "hono": "^4.11.1",
    "marked": "^17.0.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.10.15",
    "@cloudflare/workers-types": "^4.20251213.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.0.2",
    "@vitest/runner": "~3.2.4",
    "@vitest/snapshot": "~3.2.4",
    "better-sqlite3": "^12.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.54.0"
  }
}