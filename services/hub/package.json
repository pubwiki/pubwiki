{
  "name": "pubwiki-backend",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local-protocol https --https-cert-path cert.pem --https-key-path key.pem",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types",
    "migrate:local": "wrangler d1 migrations apply DB --local",
    "migrate:remote": "wrangler d1 migrations apply DB --remote",
    "prune-db:local": "rm -rf .wrangler/state && pnpm migrate:local",
    "seed": "tsx scripts/seed-mock-data.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:all": "pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@pubwiki/api": "workspace:*",
    "@pubwiki/db": "workspace:*",
    "better-auth": "^1.4.10",
    "hono": "^4.11.1",
    "marked": "^17.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.12.4",
    "@cloudflare/workers-types": "catalog:",
    "@types/node": "catalog:",
    "@vitest/runner": "catalog:vitest3",
    "@vitest/snapshot": "catalog:vitest3",
    "dotenv": "^16.6.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "vitest": "catalog:vitest3",
    "wrangler": "catalog:"
  }
}