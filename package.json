{
	"license": "FSL-1.1-ALv2",
	"packageManager": "pnpm@10.30.1",
	"scripts": {
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"build": "turbo run build",
		"check": "turbo run check",
		"test": "turbo run test",
		"deploy": "turbo run deploy",
		"deploy:dev": "turbo run deploy:dev",
		"test:e2e": "turbo run test:e2e --filter=@pubwiki/e2e",
		"test:e2e:hub": "pnpm --filter @pubwiki/e2e test:hub",
		"test:e2e:studio": "pnpm --filter @pubwiki/e2e test:studio",
		"test:e2e:integration": "pnpm --filter @pubwiki/e2e test:integration"
	},
	"devDependencies": {
		"@eslint/js": "catalog:",
		"eslint": "catalog:",
		"eslint-config-prettier": "catalog:",
		"eslint-plugin-boundaries": "catalog:",
		"eslint-plugin-svelte": "catalog:",
		"globals": "catalog:",
		"turbo": "catalog:",
		"typescript": "catalog:",
		"typescript-eslint": "catalog:",
		"vitest": "catalog:"
	}
}
